rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the logged-in user is an Admin
    function isAdmin() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Users Collection Rules
    match /users/{userId} {
      // Users can read/write their own profile data; Admins can read/write ALL profiles
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // Orders Collection Rules
    match /orders/{orderId} {
      // Users can create orders and view their own; Admins can manage all orders
      allow create: if request.auth != null;
      allow read, update, delete: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Contacts / Messages Collection Rules
    match /contacts/{contactId} {
      // Anyone can submit a contact form message; Only admins can read/manage them
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
    
    // Reviews Collection Rules
    match /reviews/{reviewId} {
      allow read: if true; // Public can see reviews
      allow create: if request.auth != null; // Registered users can write reviews
      allow update, delete: if isAdmin(); // Only admins can moderate reviews
    }
  }
}
